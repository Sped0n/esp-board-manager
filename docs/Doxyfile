PROJECT_NAME = "ESP Board Manager Programming Guide"

## The 'INPUT' statement below is used as input by script 'gen-df-input.py'
## to automatically generate API reference list files header_file.inc
## These files are placed in '_inc' directory
## and used to include in API reference documentation

INPUT =
## Public API headers exposed under esp_board_manager/include/
INPUT += $(PROJECT_PATH)/esp_board_manager/include/esp_board_manager.h
INPUT += $(PROJECT_PATH)/esp_board_manager/include/esp_board_device.h
INPUT += $(PROJECT_PATH)/esp_board_manager/include/esp_board_periph.h
INPUT += $(PROJECT_PATH)/esp_board_manager/include/esp_board_manager_defs.h
INPUT += $(PROJECT_PATH)/esp_board_manager/include/esp_board_manager_err.h

## Get warnings for functions that have no documentation for their parameters or return value
##
WARN_NO_PARAMDOC = YES

## Enable preprocessing and remove __attribute__(...) expressions from the INPUT files
##
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
PREDEFINED             = \
    $(ENV_DOXYGEN_DEFINES) \
    __attribute__(x)= \
    IRAM_ATTR=

## Do not complain about not having dot
##
HAVE_DOT = NO

## Generate XML that is required for Breathe
##
GENERATE_XML    = YES
XML_OUTPUT      = xml

GENERATE_HTML   = NO
HAVE_DOT        = NO
GENERATE_LATEX  = NO
GENERATE_MAN    = YES
GENERATE_RTF    = NO

## Skip distracting progress messages
##
QUIET = YES
